APP_ENV=production
APP_DEBUG=false

# Managed hosts normally provide PORT automatically.
PORT=3000
DEFAULT_TIMEZONE=America/New_York

# Local default. For production PostgreSQL, change this to postgres and set DATABASE_URL.
DATABASE_CLIENT=sqlite
DATABASE_PATH=storage/database/app.sqlite
DATABASE_URL=
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL_ENABLED=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

BITLY_ACCESS_TOKEN=
BITLY_DOMAIN=bit.ly
BITLY_GROUP_GUID=
BITLY_TIMEOUT_MS=8000

QR_BASE_URL=https://api.qrserver.com/v1/create-qr-code/
QR_SIZE=300x300

# Authentication is always on. Every route requires a signed-in user account
# except /login and /health. Sign-in accounts live in the database.
#
# Bootstrap: the setup console at /setup is unlocked with these credentials and
# is used to create administrator accounts. Admins then sign in normally and
# manage member accounts from the in-app Users page. Leave blank to disable the
# setup console (only do this after at least one admin exists).
SETUP_ADMIN_USERNAME=
SETUP_ADMIN_PASSWORD=

# Secret used to sign session cookies. Set a long random value in production so
# sessions survive restarts and cannot be forged. The app will not start without
# this value. Generate one with: openssl rand -hex 32
TRACKING_SECRET_ENCRYPTION_KEY=

# Session lifetime in seconds (default 12 hours).
SESSION_TTL_SECONDS=43200

UTM_BUILDER_LOG_PATH=storage/logs/utm-builder.log

# Public HTTPS URL used in notification email links.
APP_BASE_URL=https://utm.justflownh.com

# SMTP delivery. Compatible with Amazon SES SMTP and other SMTP providers.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=JF UTM Builder <notifications@justflownh.com>
