APP_ENV=production
APP_DEBUG=false

# Managed hosts normally provide PORT automatically.
PORT=3000
DEFAULT_TIMEZONE=America/New_York

DATABASE_CLIENT=postgres
DATABASE_URL=
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL_ENABLED=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

BITLY_ACCESS_TOKEN=
BITLY_DOMAIN=bit.ly
BITLY_GROUP_GUID=
BITLY_TIMEOUT_MS=8000

QR_BASE_URL=https://api.qrserver.com/v1/create-qr-code/
QR_SIZE=300x300

LIBRARY_AUTH_ENABLED=true
LIBRARY_AUTH_USERNAME=
LIBRARY_AUTH_PASSWORD=
LIBRARY_AUTH_REALM=JF UTM Builder
TRACKING_SECRET_ENCRYPTION_KEY=

UTM_BUILDER_LOG_PATH=storage/logs/utm-builder.log
